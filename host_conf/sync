#!/usr/bin/env sh
set -eu

HOST="${HOST:-coffee.zclub.cool}"
SSH_USER="${SSH_USER:-root}"
REMOTE="${SSH_USER}@${HOST}"
ENVIRONMENT="${1:-prod}"
GOOS="${GOOS:-linux}"
GOARCH="${GOARCH:-amd64}"
GOCACHE="${GOCACHE:-/tmp/coffee_server_go-build}"
CERT_FULLCHAIN="${CERT_FULLCHAIN:-/etc/ssl/zclub_cool/fullchain.pem}"
CERT_PRIVKEY="${CERT_PRIVKEY:-/etc/ssl/zclub_cool/privkey.pem}"
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
PROJECT_DIR="$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)"
NGINX_DIR="${SCRIPT_DIR}/nginx"
REMOTE_TMP="/tmp/coffee_server_sync"
BACKUP_SUFFIX="$(date +%Y%m%d%H%M%S)"
CONTROL_PATH="/tmp/coffee_${SSH_USER}_${HOST}_$$"

case "$ENVIRONMENT" in
    prod)
        APP_DIR="${APP_DIR:-/zclub/coffee/coffee_server}"
        SERVICE_NAME="${SERVICE_NAME:-coffee}"
        SYSTEMD_SERVICE_FILE="coffee.service"
        OLD_SERVICE_NAME="coffee-ws-server"
        ;;
    dev)
        APP_DIR="${APP_DIR:-/zclub/coffee/coffee_server_dev}"
        SERVICE_NAME="${SERVICE_NAME:-coffee_dev}"
        SYSTEMD_SERVICE_FILE="coffee_dev.service"
        OLD_SERVICE_NAME=""
        ;;
    *)
        echo "Usage: $0 [prod|dev]" >&2
        exit 1
        ;;
esac

ssh_remote() {
    ssh -o ControlMaster=auto -o ControlPersist=300 -o ControlPath="$CONTROL_PATH" "$REMOTE" "$@"
}

scp_remote() {
    scp -o ControlMaster=auto -o ControlPersist=300 -o ControlPath="$CONTROL_PATH" "$@"
}

cleanup() {
    ssh -o ControlPath="$CONTROL_PATH" -O exit "$REMOTE" >/dev/null 2>&1 || true
}
trap cleanup EXIT

cd "$PROJECT_DIR"

if [ ! -f "$NGINX_DIR/nginx.conf" ]; then
    echo "Missing local nginx config: $NGINX_DIR/nginx.conf" >&2
    exit 1
fi

if [ ! -f "$NGINX_DIR/conf.d/coffee.zclub.cool.conf" ]; then
    echo "Missing local nginx config: $NGINX_DIR/conf.d/coffee.zclub.cool.conf" >&2
    exit 1
fi

if [ ! -f "$PROJECT_DIR/deploy/systemd/$SYSTEMD_SERVICE_FILE" ]; then
    echo "Missing local systemd service: $PROJECT_DIR/deploy/systemd/$SYSTEMD_SERVICE_FILE" >&2
    exit 1
fi

echo "Deploying ${ENVIRONMENT} environment as ${SERVICE_NAME}.service"
echo "Building ${GOOS}/${GOARCH} binary"
mkdir -p bin
mkdir -p "$GOCACHE"
CGO_ENABLED=0 GOCACHE="$GOCACHE" GOOS="$GOOS" GOARCH="$GOARCH" go build -o bin/coffee_server .

echo "Preparing remote directories on ${REMOTE}"
ssh_remote "mkdir -p '$APP_DIR' '$REMOTE_TMP/nginx/conf.d' /etc/nginx/conf.d /etc/systemd/system"

echo "Checking remote TLS certificate"
ssh_remote "test -r '$CERT_FULLCHAIN' && test -r '$CERT_PRIVKEY' || { echo 'Missing TLS certificate: $CERT_FULLCHAIN or $CERT_PRIVKEY' >&2; exit 1; }"

echo "Syncing project to ${REMOTE}:${APP_DIR}"
LC_ALL=C COPYFILE_DISABLE=1 tar --no-xattrs \
    --exclude='.git' \
    --exclude='.agents' \
    --exclude='.codex' \
    --exclude='.cache' \
    --exclude='.DS_Store' \
    --exclude='config/secret.go' \
    --exclude='host_conf/nginx/conf.d/alone.conf' \
    -czf - . | ssh_remote "LC_ALL=C tar -xzf - -C '$APP_DIR'"

echo "Uploading nginx and systemd config"
scp_remote "$NGINX_DIR/nginx.conf" "$REMOTE:$REMOTE_TMP/nginx/nginx.conf"
scp_remote "$NGINX_DIR/conf.d/coffee.zclub.cool.conf" "$REMOTE:$REMOTE_TMP/nginx/conf.d/coffee.zclub.cool.conf"
scp_remote "$PROJECT_DIR/deploy/systemd/$SYSTEMD_SERVICE_FILE" "$REMOTE:/etc/systemd/system/${SERVICE_NAME}.service"

echo "Installing nginx config on ${HOST}"
ssh_remote "\
cp -a /etc/nginx/nginx.conf /etc/nginx/nginx.conf.${BACKUP_SUFFIX}.bak && \
if [ -f /etc/nginx/conf.d/coffee.zclub.cool.conf ]; then cp -a /etc/nginx/conf.d/coffee.zclub.cool.conf /etc/nginx/conf.d/coffee.zclub.cool.conf.${BACKUP_SUFFIX}.bak; fi && \
cp '$REMOTE_TMP/nginx/nginx.conf' /etc/nginx/nginx.conf && \
cp '$REMOTE_TMP/nginx/conf.d/coffee.zclub.cool.conf' /etc/nginx/conf.d/coffee.zclub.cool.conf && \
if ! nginx -t; then \
    cp -a /etc/nginx/nginx.conf.${BACKUP_SUFFIX}.bak /etc/nginx/nginx.conf; \
    if [ -f /etc/nginx/conf.d/coffee.zclub.cool.conf.${BACKUP_SUFFIX}.bak ]; then cp -a /etc/nginx/conf.d/coffee.zclub.cool.conf.${BACKUP_SUFFIX}.bak /etc/nginx/conf.d/coffee.zclub.cool.conf; fi; \
    nginx -t || true; \
    exit 1; \
fi"

echo "Restarting service and reloading nginx on ${HOST}"
ssh_remote "systemctl daemon-reload && systemctl enable --now '${SERVICE_NAME}' && systemctl restart '${SERVICE_NAME}' && if [ -n '$OLD_SERVICE_NAME' ] && systemctl list-unit-files | grep -q \"^${OLD_SERVICE_NAME}.service\"; then systemctl disable --now '$OLD_SERVICE_NAME' || true; fi && systemctl reload nginx"

echo "Done"
